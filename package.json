{
  "name": "q-note",
  "version": "0.0.12",
  "description": "A lightweight desktop note app built with Tauri.",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/ywenhao/q-note#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ywenhao/q-note.git"
  },
  "bugs": {
    "url": "https://github.com/ywenhao/q-note/issues"
  },
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "tauri:dev": "tauri dev",
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "release": "bumpp package.json src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/Cargo.lock --git-check --commit \"release: v%s\" --tag \"v%s\"",
    "release:major": "pnpm run release --release major",
    "release:minor": "pnpm run release --release minor",
    "release:patch": "pnpm run release --release patch",
    "update:manifest": "node scripts/generate-update-manifest.mjs",
    "tauri": "tauri",
    "format": "vp format",
    "format:check": "vp format --check",
    "typecheck": "tsc --build --noEmit",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bumpp": "^11.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plus": "^0.1.24"
  }
}
