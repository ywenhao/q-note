{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "tauri: dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["tauri", "dev"],
      "isBackground": true,
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "ts: typecheck",
      "type": "shell",
      "command": "pnpm",
      "args": ["exec", "tsc", "--noEmit"],
      "problemMatcher": "$tsc",
      "group": "test"
    },
    {
      "label": "cargo: check",
      "type": "shell",
      "command": "cargo",
      "args": ["check"],
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "problemMatcher": "$rustc",
      "group": "test"
    }
  ]
}
